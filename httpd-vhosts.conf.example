# smart-cabinet-cu
# ใส่ใน VirtualHost ที่ใช้ (หรือ Include ใน httpd-vhosts.conf ของ Apache)
# ลำดับสำคัญ: /api/smart-cabinet-cu/v1/ ต้องอยู่ก่อน /smart-cabinet-cu/ เพื่อไม่ให้ API ชน frontend

# ให้แอปรู้ว่าเข้าผ่าน HTTPS และ host ภายนอก (ใช้กับ NextAuth / redirect)
<LocationMatch "^/(smart-cabinet-cu|api/smart-cabinet-cu)">
    ProxyPreserveHost On
    RequestHeader set X-Forwarded-Proto "https"
    RequestHeader set X-Forwarded-Host "phc.dyndns.biz"
</LocationMatch>

# API → Backend
<Location "/medical-supplies-api/v1/" >
    ProxyPreserveHost On
    ProxyPass "http://10.11.9.84:3000/api/smart-cabinet-vn/v1/"
    ProxyPassReverse "http://10.11.9.84:3000/api/smart-cabinet-vn/v1/"

</Location>

# Frontend: RewriteRule [P] จัดการทั้ง /smart-cabinet-cu และ /smart-cabinet-cu/...
RewriteEngine On
RewriteRule ^/smart-cabinet-cu(/.*)?$ http://10.11.9.84:4100/smart-cabinet-cu$1 [P,L]
ProxyPassReverse /smart-cabinet-cu http://10.11.9.84:4100/smart-cabinet-cu

